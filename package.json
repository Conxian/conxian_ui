{
  "name": "conxian_ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "sed -i 's/\"jsx\": \"react-jsx\"/\"jsx\": \"preserve\"/g' tsconfig.json && next build && sed -i 's/\"jsx\": \"preserve\"/\"jsx\": \"react-jsx\"/g' tsconfig.json",
    "start": "npx serve@latest out -p ${PORT:-10000} -s",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "sed -i 's/\"jsx\": \"preserve\"/\"jsx\": \"react-jsx\"/g' tsconfig.json && vitest run",
    "prepare": "node scripts/prepare.cjs"
  },
  "dependencies": {
